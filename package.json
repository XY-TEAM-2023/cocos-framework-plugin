        "methods": [
          "promptUploadAfterBuild"
        ]
      },
      "set-tree-data": {
        "methods": [
          "upload.setTreeData"
        ]
      },
      "update-progress": {
        "methods": [
          "upload.updateProgress"
        ]
      },
      "set-uploading": {
        "methods": [
          "upload.setUploading"
        ]
