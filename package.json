{
  "package_version": 2,
  "version": "1.0.0",
  "name": "framework-plugin",
  "description": "i18n:framework-plugin.description",
  "main": "./dist/main.js",
  "devDependencies": {
    "@types/node": "^16.0.1",
    "typescript": "^4.3.4"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.x"
  },
  "panels": {
    "log": {
      "title": "更新框架",
      "type": "simple",
      "main": "dist/panels/log",
      "size": {
        "min-width": 500,
        "min-height": 300,
        "width": 600,
        "height": 400
      },
      "flags": {
        "alwaysOnTop": true
      }
    },
    "upload": {
      "title": "上传到 R2",
      "type": "simple",
      "main": "dist/panels/upload",
      "size": {
        "min-width": 450,
        "min-height": 350,
        "width": 600,
        "height": 500
      },
      "flags": {
        "alwaysOnTop": true
      }
    },
    "r2config": {
      "title": "配置 R2",
      "type": "simple",
      "main": "dist/panels/r2config",
      "size": {
        "min-width": 350,
        "min-height": 300,
        "width": 420,
        "height": 380
      },
      "flags": {
        "alwaysOnTop": true
      }
    },
    "pages-config": {
      "title": "配置 Pages",
      "type": "simple",
      "main": "dist/panels/pages-config",
      "size": {
        "min-width": 400,
        "min-height": 400,
        "width": 480,
        "height": 520
      },
      "flags": {
        "alwaysOnTop": true
      }
    },
    "pages-deploy": {
      "title": "部署到 Pages",
      "type": "simple",
      "main": "dist/panels/pages-deploy",
      "size": {
        "min-width": 450,
        "min-height": 400,
        "width": 550,
        "height": 500
      },
      "flags": {
        "alwaysOnTop": true
      }
    },
    "pages-versions": {
      "title": "切换版本",
      "type": "simple",
      "main": "dist/panels/pages-versions",
      "size": {
        "min-width": 450,
        "min-height": 350,
        "width": 600,
        "height": 500
      },
      "flags": {
        "alwaysOnTop": true
      }
    },
    "pages-cleanup": {
      "title": "清理版本",
      "type": "simple",
      "main": "dist/panels/pages-cleanup",
      "size": {
        "min-width": 450,
        "min-height": 350,
        "width": 600,
        "height": 500
      },
      "flags": {
        "alwaysOnTop": true
      }
    }
  },
  "contributions": {
    "builder": "./dist/builder",
    "menu": [
      {
        "path": "框架",
        "label": "更新框架",
        "message": "update-framework"
      },
      {
        "path": "框架",
        "label": "切换框架版本",
        "message": "switch-version"
      },
      {
        "path": "框架",
        "label": "修复框架",
        "message": "repair-framework"
      },
      {
        "path": "框架/开发/框架",
        "label": "推送版本",
        "message": "publish-framework"
      },
      {
        "path": "框架/开发/插件",
        "label": "本地构建",
        "message": "build-plugin"
      },
      {
        "path": "框架/开发/插件",
        "label": "推送版本",
        "message": "publish-plugin"
      },
      {
        "path": "框架/R2",
        "label": "配置 R2",
        "message": "config-r2"
      },
      {
        "path": "框架/R2",
        "label": "上传到 R2",
        "message": "upload-to-r2"
      },
      {
        "path": "框架/R2",
        "label": "✅ 开启构建后自动询问上传",
        "message": "enable-auto-prompt"
      },
      {
        "path": "框架/R2",
        "label": "❌ 关闭构建后自动询问上传",
        "message": "disable-auto-prompt"
      },
      {
        "path": "框架",
        "label": "关于",
        "message": "show-about"
      },
      {
        "path": "框架/Pages",
        "label": "配置 Pages",
        "message": "config-pages"
      },
      {
        "path": "框架/Pages",
        "label": "部署到 Pages",
        "message": "deploy-to-pages"
      },
      {
        "path": "框架/Pages",
        "label": "切换版本",
        "message": "switch-pages-version"
      },
      {
        "path": "框架/Pages",
        "label": "清理版本",
        "message": "cleanup-pages-versions"
      }
