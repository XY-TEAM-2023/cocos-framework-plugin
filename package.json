      "do-publish-framework": {
        "methods": [
          "doPublishFramework"
        ]
      },
      "publish-plugin": {
        "methods": [
          "publishPlugin"
        ]
      },
      "do-publish-plugin": {
        "methods": [
          "doPublishPlugin"
        ]
      },
      "show-about": {
        "methods": [
          "showAbout"
        ]
      },
      "open-log-panel": {
        "methods": [
          "openLogPanel"
        ]
      },
      "append-log": {
        "methods": [
          "log.appendLog"
        ]
      },
