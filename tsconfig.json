{
    "compilerOptions": {
        "target": "ES2017",
        "module": "commonjs",
        "strict": true,
        "esModuleInterop": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "declaration": true,
        "sourceMap": true,
        "skipLibCheck": true,
        "moduleResolution": "node",
        "resolveJsonModule": true,
        "lib": ["ES2017", "DOM"]
    },
    "include": ["src/**/*.ts", "@types/**/*.d.ts"],
    "exclude": ["node_modules", "dist"]
}
